{
  "name": "cc-wf-studio-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for cc-wf-studio (VSCode extension, MCP server, CLI, and core schema)",
  "repository": {
    "type": "git",
    "url": "https://github.com/breaking-brake/cc-wf-studio"
  },
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "check": "pnpm -r run check",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "test": "pnpm -r run test",
    "ccwf": "node packages/cli/dist/cli.js",
    "ccwf:dev": "tsx packages/cli/src/cli.ts"
  },
  "devDependencies": {
    "@cc-wf-studio/cli": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^24.2.0",
    "semantic-release-monorepo": "^8.0.2",
    "tsx": "^4.19.2"
  }
