          "prompt": "Thank you, {{userName}}! I'll help you with: {{task}}\n\nIs this correct?",
          "variables": {}
        }
      },
      {
        "id": "ask-confirm",
        "type": "askUserQuestion",
        "name": "ask-confirm",
        "position": { "x": 900, "y": 200 },
