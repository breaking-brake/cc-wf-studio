          "multiSelect": false,
          "useAiSuggestions": false,
          "outputPorts": 2
        }
      },
      {
        "id": "prompt-process",
        "type": "prompt",
        "name": "prompt-process",
        "position": { "x": 1100, "y": 150 },
        "data": {
          "label": "Process Task",
          "prompt": "Now processing the task: {{task}}\n\nPlease proceed with the actual work.",
          "variables": {}
        }
      },
      {
        "id": "prompt-restart",
        "type": "prompt",
        "name": "prompt-restart",
        "position": { "x": 1100, "y": 300 },
        "data": {
          "label": "Restart",
          "prompt": "Starting over. Please enter your name again.",
          "variables": {}
        }
      },
      {
        "id": "end-1",
        "type": "end",
        "name": "end-1",
